# Where bronze Parquet is written. Used by both `make pipeline` and Docker.
# Must be an ABSOLUTE path (Docker mounts it host==container).
#   laptop:  DATA_DIR=/Users/you/dev/freeflake/data/warehouse
#   sandbox: DATA_DIR=/mnt/NeoNAS
DATA_DIR=/Users/you/dev/freeflake/data/warehouse

# Docker only: absolute path to the repo deploy key so runs can git_clone main.
SSH_KEY_PATH=/home/you/.ssh/freeflake_deploy

QB_CLIENT_ID=your_client_id
QB_CLIENT_SECRET=your_client_secret
YNAB_TOKEN=your_personal_access_token
HA_TOKEN=your_long_lived_access_token
HA_URL=http://home.mcc:8123
EARLY_API_KEY=your_api_key
EARLY_API_SECRET=your_api_secret